# ── Sunsteer configuration ───────────────────────────────────────────────────
# Copy to .env and fill in everything marked REQUIRED. Static/hardware settings
# live here; runtime tuning (thresholds, delays, prices) lives in the database
# and is editable in the web UI under "Settings".

# ── Required: hardware ──────────────────────────────────────────────────────
# IP (or hostname — resolved to an IP at startup) of the SMA Sunny Home Manager 2.0,
# used as the source filter for Speedwire telegrams.
SHM_HOST=
# Base URL of the Shelly (Gen2, e.g. Pro 1PM) wired to the heat pump's SG-Ready input.
SHELLY_URL=http://192.168.x.x

# ── Required: PV site (used for the forecast-based adaptive threshold) ──────
PV_LAT=
PV_LON=
# Roof planes as JSON: [[declination_deg, azimuth_deg, kwp], ...]
# Azimuth: 0 = south, -90 = east, +90 = west. Example east/west split:
# PV_PLANES=[[28,-90,7.26],[28,90,7.92]]
PV_PLANES=
# IANA timezone of the site (used by forecast and day boundaries).
PV_TZ=UTC

# ── Required: database & UI credentials ─────────────────────────────────────
DB_USER=sunsteer
DB_PASS=
DB_NAME=energy
# Web UI login (HTTP Basic). The UI is FAIL-CLOSED: without ADMIN_PASS it serves 503.
ADMIN_USER=admin
ADMIN_PASS=

# ── Optional: release version ────────────────────────────────────────────────
# Image tag pulled from ghcr.io/slippyex/sunsteer (default: 0.5.2). Use a newer
# release tag to upgrade; `docker compose up -d --build` builds from source instead.
#SUNSTEER_VERSION=0.5.2

# ── Optional: meter driver ───────────────────────────────────────────────────
# sma_shm (default) reads the real SHM. mock generates a synthetic surplus curve —
# no hardware needed (SHM_HOST/SHELLY_URL may stay empty). See docker-compose.demo.yml
# for the zero-config demo instead.
#METER_DRIVER=sma_shm

# Relay driver: shelly (default). The relay must support a hardware auto-off watchdog.
#RELAY_DRIVER=shelly

# Multicast interface for the SMA Speedwire join. Default empty = the default-route NIC.
# Set to the IP of the NIC on the SHM's L2 segment on a multi-homed host (e.g. several NICs
# under network_mode: host), otherwise the join may land on the wrong interface.
#SMA_IFACE_IP=

# ── Optional: SMA inverter telemetry (Modbus TCP) ────────────────────────────
# Leave INVERTER_HOST empty to disable.
#INVERTER_HOST=
#INVERTER_PORT=502
#INVERTER_UNIT_ID=3

# ── Optional: behaviour ──────────────────────────────────────────────────────
# Shelly hardware watchdog: relay auto-off if the controller stops re-arming it.
# Raise (e.g. 180) only if your Shelly sits on flaky WiFi.
#SHELLY_AUTOOFF_SECONDS=60
# Solar elevation (degrees) below which no PV surplus is possible -> the controller stops
# load-compensating and releases the heat pump (no running on grid power after dark).
# Default 3.0; needs PV_LAT/PV_LON (already required).
#PV_SUN_MIN_ELEVATION_DEG=3.0
# Exporter TSDB write cadence (seconds). The UI uses it for runtime/kWh math, so keep
# both in sync. Default 60; rarely changed.
#TSDB_FLUSH_SECONDS=60
# Interface the exporter's /state server binds to. Default empty = all interfaces. Set to
# a specific IP to restrict who can read the live control telemetry (carries no secrets).
#STATE_BIND=
# Interface the controller's /status + /healthz server binds to. Default empty = all
# interfaces. Set to a specific IP to restrict the controller's operational telemetry.
#STATUS_BIND=
# Host interface the web UI binds to. Default 127.0.0.1 (loopback) — HTTP Basic auth
# has no TLS, so do NOT expose it on the LAN directly; front it with a TLS reverse proxy.
# Set 0.0.0.0 only on a trusted network.
#UI_BIND=127.0.0.1
# CSRF: state-changing POSTs require the browser's Origin to match the UI's host. Behind a
# reverse proxy the public origin differs — set it here (scheme + host[:port]) so it's
# accepted, e.g. ALLOWED_ORIGIN=https://sunsteer.example.com. Empty = same-host only.
#ALLOWED_ORIGIN=
# Web UI default language: en | de (every user can switch in the header).
#UI_DEFAULT_LANG=en
# Optional place name shown after "Weather" in the weather panel (e.g. your town).
# Empty -> the panel just reads "Weather".
#WEATHER_LOCATION=
# Link to your Grafana, shown in the UI header when set.
#GRAFANA_URL=

# ── Optional: heat-pump telemetry (docker compose --profile vicare) ─────────
# Driver: vicare (default, Viessmann ViCare cloud API) | mock (synthetic, no creds needed).
#HEATPUMP_DRIVER=vicare
# Display label for the heat-pump card in the UI. Empty → neutral "Heat pump" / "Wärmepumpe".
#HEATPUMP_LABEL=Vitocal 250 A06
# Poll cadence in seconds (how often the driver is called). Default 300.
#HEATPUMP_POLL_SECONDS=300

# ── vicare driver credentials (required when HEATPUMP_DRIVER=vicare) ────────
#VICARE_USER=
#VICARE_PASS=
#VICARE_CLIENT_ID=
# Max ViCare API calls per day (rate budget; the exporter spaces its polling to fit).
#VICARE_DAILY_CAP=1400
# Where the rate budget is persisted so a restart does NOT grant a fresh daily quota
# (kept on the vicare-token volume mounted at /data).
#VICARE_BUDGET_FILE=/data/vicare_budget.json

# ── Optional: monitoring stack (docker-compose.monitoring.yml) ──────────────
# Grafana binds loopback by default. Set a STRONG password and GRAFANA_BIND=0.0.0.0
# (ideally behind a TLS reverse proxy) before exposing it beyond the host.
#GRAFANA_ADMIN_USER=admin
#GRAFANA_ADMIN_PASS=
#GRAFANA_BIND=127.0.0.1
